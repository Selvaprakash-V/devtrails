PORT=5000
# Replace with your MongoDB connection string. DO NOT commit real credentials.
# Example (Mongo Atlas): mongodb+srv://<user>:<password>@cluster0.mongodb.net/devtrails?retryWrites=true&w=majority
MONGODB_URI=YOUR_MONGODB_URI_HERE

# JWT settings
# Replace JWT_SECRET with a secure random string (min 32 chars) in production
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRE=7d
NODE_ENV=development

# Weather API (OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# AQI API (WAQI)
AQI_API_KEY=your_waqi_api_key
AQI_BASE_URL=https://api.waqi.info

# Payment provider (Razorpay) - use test keys for development
RAZORPAY_KEY_ID=rzp_test_key_id
RAZORPAY_KEY_SECRET=rzp_test_key_secret

# Disruption thresholds (tweak for your market)
RAIN_THRESHOLD_MM=80
HEAT_THRESHOLD_CELSIUS=42
AQI_THRESHOLD=300
FLOOD_ALERT_LEVEL=high

# Cron interval (minutes) for disruption checks
DISRUPTION_CHECK_INTERVAL=15

# Notes:
# - Copy this file to `.env` and fill real secrets locally.
# - Do NOT commit your `.env` to source control.
